<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tony Courier</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f4f6f9;
      color: #333;
    }
    header {
      background: #0d6efd;
      color: white;
      padding: 20px;
      text-align: center;
    }
    header h1 {
      margin: 0;
    }
    nav {
      text-align: center;
      padding: 10px;
      background: #084298;
    }
    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
      font-weight: bold;
    }
    .container {
      max-width: 1000px;
      margin: auto;
      padding: 20px;
    }
    .hero {
      text-align: center;
      padding: 50px 20px;
    }
    .hero h2 {
      font-size: 2em;
    }
    .btn {
      display: inline-block;
      padding: 12px 25px;
      background: #0d6efd;
      color: white;
      text-decoration: none;
      border-radius: 5px;
      margin-top: 15px;
    }
    .services {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 30px;
    }
    .card {
      background: white;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    footer {
      background: #212529;
      color: white;
      text-align: center;
      padding: 20px;
      margin-top: 40px;
    }
    .contact {
      text-align: center;
      margin-top: 30px;
    }
  </style>
</head>
<body>

<header>
  <h1>Tony Courier</h1>
  <p>Fast • Reliable • Professional Delivery Services</p>
</header>

<nav>
  <a href="#">Home</a>
  <a href="#services">Services</a>
  <a href="#contact">Contact</a>
</nav>

<div class="container">

  <section class="hero">
    <h2>Your Trusted Courier & Delivery Partner</h2>
    <p>We provide fast and secure delivery solutions for individuals and businesses.</p>
    <a class="btn" href="tel:+61402553901">Call Now</a>
  </section>

  <section id="services">
    <h2>Our Services</h2>
    <div class="services">
      <div class="card">
        <h3>Same-Day Delivery</h3>
        <p>Quick and reliable same-day delivery across your area.</p>
      </div>
      <div class="card">
        <h3>Express Courier</h3>
        <p>Fast and secure delivery for urgent packages.</p>
      </div>
      <div class="card">
        <h3>Business Deliveries</h3>
        <p>Professional delivery solutions tailored for businesses.</p>
      </div>
    </div>
  </section>

  <section id="contact" class="contact">
    <h2>Contact Us</h2>
    <p><strong>Phone:</strong> +61 402 553 901</p>
    <p><strong>Email:</strong> tnydelivery@gmail.com</p>
    <p>Available 7 days a week</p>
  </section>

</div>

<footer>
  <p>© 2026 Tony Courier. All rights reserved.</p>
</footer>

</body>
</html>
